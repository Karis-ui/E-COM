{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://ktech-industries.vercel.app/api/v1",
    "REACT_APP_WS_URL": "wss://ktech-industries.vercel.app",
    "REACT_APP_MPESA_ENVIRONMENT": "production"
  }
}